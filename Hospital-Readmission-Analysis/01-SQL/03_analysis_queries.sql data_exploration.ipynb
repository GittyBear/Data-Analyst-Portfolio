1️⃣ Readmission Rate:- 
              SELECT readmitted, COUNT(*) AS patients
              FROM diabetic_data
              GROUP BY readmitted;
2️⃣ Average Hospital Stay by Age:-
              SELECT age,
              AVG(time_in_hospital) AS avg_stay
              FROM diabetic_data
              GROUP BY age
              ORDER BY age;
3️⃣ Medication Impact:-
              SELECT insulin,
              COUNT(*) AS patients
              FROM diabetic_data
              GROUP BY insulin;
4️⃣ Emergency Visits:- 
              SELECT number_emergency,
              COUNT(*) AS patients
              FROM diabetic_data
              GROUP BY number_emergency
              ORDER BY patients DESC;
